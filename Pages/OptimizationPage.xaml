<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MyTool.OptimizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MyTool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="30" Padding="10">

            <StackPanel Spacing="5">
                <TextBlock Text="SYSTEM OPTIMIZATION" FontSize="24" FontWeight="Bold" Foreground="#F4F4F5" CharacterSpacing="50"/>
                <TextBlock Text="Run advanced utilities and toggle system tweaks to boost performance." FontSize="13" Foreground="#71717A"/>
            </StackPanel>


            <StackPanel Spacing="15">
                <TextBlock Text="Quick Actions" FontSize="16" FontWeight="SemiBold" Foreground="#A1A1AA"/>
                <GridView SelectionMode="None" IsItemClickEnabled="False" HorizontalAlignment="Left">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.Items>

                        <Border Margin="0,0,20,20" Width="280" Height="160" Background="#141419" BorderBrush="#22222C" BorderThickness="1" CornerRadius="12" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE74D;" Foreground="#A3E635" FontSize="16" FontFamily="Segoe MDL2 Assets"/>
                                        <TextBlock Text="Disk Cleanup" Foreground="#F4F4F5" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="Clears Windows and User temporary directories to reclaim storage space." FontSize="12" Foreground="#71717A" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Row="1" Click="CleanDisk_Click" Content="Analyze &amp; Clean" HorizontalAlignment="Stretch" Background="#1A1A22" Foreground="#F4F4F5" BorderBrush="#2D2D3D" CornerRadius="6"/>
                            </Grid>
                        </Border>

                        <Border Margin="0,0,20,20" Width="280" Height="160" Background="#141419" BorderBrush="#22222C" BorderThickness="1" CornerRadius="12" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE81D;" Foreground="#A3E635" FontSize="16" FontFamily="Segoe MDL2 Assets"/>
                                        <TextBlock Text="Flush DNS Cache" Foreground="#F4F4F5" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="Clears the system network cache to resolve connectivity or speed issues." FontSize="12" Foreground="#71717A" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Row="1" Click="FlushDNS_Click" Content="Flush Cache" HorizontalAlignment="Stretch" Background="#1A1A22" Foreground="#F4F4F5" BorderBrush="#2D2D3D" CornerRadius="6"/>
                            </Grid>
                        </Border>

                        <Border Margin="0,0,20,20" Width="280" Height="160" Background="#141419" BorderBrush="#22222C" BorderThickness="1" CornerRadius="12" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE950;" Foreground="#A3E635" FontSize="16" FontFamily="Segoe MDL2 Assets"/>
                                        <TextBlock Text="Optimize Memory" Foreground="#F4F4F5" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="Trims working sets of active processes to free up physical RAM." FontSize="12" Foreground="#71717A" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Row="1" Click="OptimizeRAM_Click" Content="Optimize RAM" HorizontalAlignment="Stretch" Background="#1A1A22" Foreground="#F4F4F5" BorderBrush="#2D2D3D" CornerRadius="6"/>
                            </Grid>
                        </Border>

                    </GridView.Items>
                </GridView>
            </StackPanel>

            <StackPanel Spacing="15" HorizontalAlignment="Left" MaxWidth="1000" Width="Auto">

                <TextBlock Text="System Tweaks" FontSize="16" FontWeight="SemiBold" Foreground="#A1A1AA"/>

                <Border HorizontalAlignment="Stretch" Background="#141419" BorderBrush="#22222C" BorderThickness="1" CornerRadius="12" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="5" Margin="0,0,40,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE814;" Foreground="#A3E635" FontSize="16" FontFamily="Segoe MDL2 Assets"/>
                                <TextBlock Text="Windows Background Telemetry" Foreground="#F4F4F5" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="When disabled, it stops Windows from collecting diagnostics data and running data-logging services in the background." 
                           FontSize="12" Foreground="#71717A" TextWrapping="Wrap"/>
                        </StackPanel>

                        <ToggleSwitch x:Name="TelemetryToggle" Grid.Column="1" 
                          OffContent="Disabled" OnContent="Enabled"
                          VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border HorizontalAlignment="Stretch" Background="#141419" BorderBrush="#22222C" BorderThickness="1" CornerRadius="12" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="5" Margin="0,0,40,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8BD;" Foreground="#A3E635" FontSize="16" FontFamily="Segoe MDL2 Assets"/>
                                <TextBlock Text="Windows Tips &amp; Suggestions" Foreground="#F4F4F5" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="When disabled, it stops built-in Windows suggestions, tricks, and lock screen promotional ads." 
                           FontSize="12" Foreground="#71717A" TextWrapping="Wrap"/>
                        </StackPanel>

                        <ToggleSwitch x:Name="TipsToggle" Grid.Column="1" OffContent="Disabled" OnContent="Enabled" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>


        </StackPanel>
        
    </ScrollViewer>
</Page>
